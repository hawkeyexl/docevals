{
  "name": "docevals",
  "version": "0.1.0",
  "description": "Deterministic and LLM-as-judge evals for documentation pages, driven by frontmatter. Docs as Evals, as a tool.",
  "type": "module",
  "bin": {
    "docevals": "dist/cli.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hawkeyexl/docevals.git"
  },
  "bugs": {
    "url": "https://github.com/hawkeyexl/docevals/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "documentation",
    "evals",
    "llm-as-judge",
    "docs-as-tests",
    "frontmatter",
    "testing",
    "cli",
    "ci"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^15.0.0",
    "cross-spawn": "^7.0.6",
    "docmeta": "file:../docmeta",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^26.0.1",
    "@types/picomatch": "^4.0.3",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
