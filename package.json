{
  "name": "docevals",
  "version": "0.1.0",
  "description": "Deterministic and LLM-as-judge evals for documentation pages, driven by frontmatter. Docs as Evals, as a tool.",
  "type": "module",
  "bin": {
    "docevals": "dist/cli.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/frontmatter-0.1.json": "./schemas/frontmatter-0.1.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hawkeyexl/docevals.git"
  },
  "bugs": {
    "url": "https://github.com/hawkeyexl/docevals/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "documentation",
    "evals",
    "llm-as-judge",
    "docs-as-tests",
    "frontmatter",
    "testing",
    "cli",
    "ci"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^15.0.0",
    "cross-spawn": "^7.0.6",
    "docmeta": "^1.3.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^26.0.1",
    "@types/picomatch": "^4.0.3",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.8",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
